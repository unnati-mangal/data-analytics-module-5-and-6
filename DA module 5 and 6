          "name": "stdout",
          "text": [
            "T-statistic: 0.6383565740793474\n",
            "P-value: 0.5410804312505743\n",
            "No significant difference between datasets\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# Perform Chi-square test on categorical data\n",
        "print(\"Perform Chi-square test on categorical data\\n\")\n",
        "import pandas as pd\n",
        "from scipy import stats\n",
        "\n",
        "data = {\n",
        "    'Gender': ['F','M','F','M','F','M'],\n",
        "    'Result': ['Pass','Fail','Pass','Pass','Fail','Pass']\n",
        "}\n",
        "df = pd.DataFrame(data)\n",
        "\n",
        "table = pd.crosstab(df['Gender'], df['Result'])\n",
        "\n",
        "chi2, p, dof, exp = stats.chi2_contingency(table)\n",
        "\n",
        "print(\"Chi2:\", chi2)\n",
        "print(\"P-value:\", p)\n",
        "\n",
        "if p < 0.05:\n",
        "    print(\"Dependent variables\")\n",
        "else:\n",
        "    print(\"Independent variables\")"
      ],
