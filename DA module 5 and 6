        "# Perform t-test on two datasets\n",
        "from scipy import stats\n",
        "\n",
        "data1 = [78, 85, 96, 65, 70]\n",
        "\n",
        "data2 = [72, 80, 90, 60, 68]\n",
        "\n",
        "t, p = stats.ttest_ind(data1, data2)\n",
        "\n",
        "print(\"T-statistic:\", t)\n",
        "print(\"P-value:\", p)\n",
        "\n",
        "if p < 0.05:\n",
        "    print(\"Significant difference between datasets\")\n",
        "else:\n",
        "    print(\"No significant difference between datasets\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "zYntxspzM0OQ",
        "outputId": "a5926e9f-d814-4dcf-e57e-adc32ea0a1b5"
